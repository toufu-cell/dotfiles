[rerere]
    enabled = true
    autoupdate = true

[pull]
    ff = only

[fetch]
    prune = true
    pruneTags = true

[merge]
    conflictstyle = zdiff3

[rebase]
    autoStash = true
    updateRefs = true

[push]
    autoSetupRemote = true

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[diff]
    algorithm = histogram

[delta]
    line-numbers = true
    navigate = true
    side-by-side = false
